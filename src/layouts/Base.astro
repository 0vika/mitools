---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'mitools.dev' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="mitools.dev - Developer hub and launchpad for tools by Micah Ice" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-text-primary font-mono scanlines min-h-screen">
    <slot />
  </body>
</html>
