---
interface Props {
  name: string;
  description: string;
  tags: string[];
  url: string;
}

const { name, description, tags, url } = Astro.props;
---

<div class="project-card border border-border bg-surface rounded-md overflow-hidden
            hover:border-accent/60 hover:shadow-md
            transition-all duration-150 opacity-0 translate-y-4">
  <!-- Window chrome -->
  <div class="flex items-center gap-2 px-4 py-2 border-b border-border bg-surface">
    <span class="w-3 h-3 rounded-full border border-border bg-bg"></span>
    <span class="w-3 h-3 rounded-full border border-border bg-bg"></span>
    <span class="w-3 h-3 rounded-full border border-border bg-bg"></span>
    <span class="ml-2 text-muted text-xs font-mono">{name}</span>
  </div>

  <div class="p-6">
    <h3 class="font-display text-xl text-accent mb-2">{name}</h3>
    <p class="text-text-primary text-sm mb-4">{description}</p>
    <div class="flex flex-wrap gap-2 mb-6">
      {tags.map((tag) => (
        <span class="text-xs font-mono text-muted border border-border px-2 py-1 rounded">
          {tag}
        </span>
      ))}
    </div>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block px-4 py-2 border border-accent text-accent text-sm font-mono
             hover:bg-accent hover:text-bg transition-colors duration-150"
    >
      [ visit ]
    </a>
  </div>
</div>

<style>
  .project-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
</style>

<script>
  const cards = document.querySelectorAll('.project-card');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('visible');
          }, i * 120);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  cards.forEach((card) => observer.observe(card));
</script>
