---
interface Props {
  name: string;
  description: string;
  tags: string[];
  url: string;
}

const { name, description, tags, url } = Astro.props;
---

<div class="border border-border bg-surface rounded-md overflow-hidden
            hover:border-accent/50 hover:shadow-[0_0_20px_rgba(0,255,136,0.05)]
            transition-all duration-150">
  <!-- Window chrome -->
  <div class="flex items-center gap-2 px-4 py-2 border-b border-border">
    <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
    <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
    <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
    <span class="ml-2 text-muted text-xs font-mono">{name}</span>
  </div>

  <div class="p-6">
    <h3 class="font-display text-xl text-accent-alt mb-2">{name}</h3>
    <p class="text-text-primary text-sm mb-4">{description}</p>
    <div class="flex flex-wrap gap-2 mb-6">
      {tags.map((tag) => (
        <span class="text-xs font-mono text-muted border border-border px-2 py-1 rounded">
          {tag}
        </span>
      ))}
    </div>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block px-4 py-2 border border-accent text-accent text-sm font-mono
             hover:bg-accent hover:text-bg transition-colors duration-150"
    >
      [ visit ]
    </a>
  </div>
</div>
